{
  "name": "quorum",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "knip": "knip",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "prepare": "husky",
    "pre-commit": "npm run type-check && npm run lint && npm run format:check && npm run build && npm test",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
